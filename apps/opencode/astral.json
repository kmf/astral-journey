{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "blackhole_bg":       "#0d0f1e",
    "blackhole_bg_soft":  "#14172a",
    "blackhole_bg_hi":    "#1c2038",
    "blackhole_border":   "#2a2f4d",
    "blackhole_fg":       "#ebe8d2",
    "blackhole_fg_alt":   "#fdfbe4",
    "blackhole_fg_muted": "#8b90bd",
    "blackhole_yellow":   "#ffcc66",
    "blackhole_orange":   "#ff9933",
    "blackhole_red":      "#ff6e6e",
    "blackhole_magenta":  "#cc99cc",
    "blackhole_violet":   "#b78ae0",
    "blackhole_blue":     "#6a97ea",
    "blackhole_teal":     "#38a8d0",
    "blackhole_green":    "#7ed4a3",

    "supernova_bg":          "#fdf9ec",
    "supernova_bg_soft":     "#f6f0dc",
    "supernova_bg_hi":       "#efe8cf",
    "supernova_border":      "#e2d8ba",
    "supernova_fg":          "#292140",
    "supernova_fg_alt":      "#1c1730",
    "supernova_fg_muted":    "#5d5c78",
    "supernova_yellow":      "#9d650c",
    "supernova_orange":      "#b65608",
    "supernova_red":         "#d62e3f",
    "supernova_magenta":     "#a34fa8",
    "supernova_violet":      "#7b4fc0",
    "supernova_blue":        "#2f5fc7",
    "supernova_teal":        "#006699",
    "supernova_green":       "#1d8156",

    "diff_add_bg_dark":  "#1f2f33",
    "diff_rem_bg_dark":  "#341e2b",
    "diff_add_bg_light": "#dee9d8",
    "diff_rem_bg_light": "#f8ded5"
  },
  "theme": {
    "primary":         { "dark": "blackhole_blue",    "light": "supernova_blue" },
    "secondary":       { "dark": "blackhole_violet",  "light": "supernova_violet" },
    "accent":          { "dark": "blackhole_yellow",  "light": "supernova_yellow" },
    "error":           { "dark": "blackhole_red",     "light": "supernova_red" },
    "warning":         { "dark": "blackhole_orange",  "light": "supernova_orange" },
    "success":         { "dark": "blackhole_green",   "light": "supernova_green" },
    "info":            { "dark": "blackhole_teal",    "light": "supernova_teal" },

    "text":            { "dark": "blackhole_fg",       "light": "supernova_fg" },
    "textMuted":       { "dark": "blackhole_fg_muted", "light": "supernova_fg_muted" },

    "background":      { "dark": "blackhole_bg",      "light": "supernova_bg" },
    "backgroundPanel": { "dark": "blackhole_bg_soft", "light": "supernova_bg_soft" },
    "backgroundElement": { "dark": "blackhole_bg_hi", "light": "supernova_bg_hi" },

    "border":          { "dark": "blackhole_border",  "light": "supernova_border" },
    "borderActive":    { "dark": "blackhole_yellow",  "light": "supernova_yellow" },
    "borderSubtle":    { "dark": "blackhole_border",  "light": "supernova_border" },

    "diffAdded":              { "dark": "blackhole_green", "light": "supernova_green" },
    "diffRemoved":            { "dark": "blackhole_red",   "light": "supernova_red" },
    "diffContext":            { "dark": "blackhole_fg_muted", "light": "supernova_fg_muted" },
    "diffHunkHeader":         { "dark": "blackhole_blue",  "light": "supernova_blue" },
    "diffHighlightAdded":     { "dark": "blackhole_green", "light": "supernova_green" },
    "diffHighlightRemoved":   { "dark": "blackhole_red",   "light": "supernova_red" },
    "diffAddedBg":            { "dark": "diff_add_bg_dark", "light": "diff_add_bg_light" },
    "diffRemovedBg":          { "dark": "diff_rem_bg_dark", "light": "diff_rem_bg_light" },
    "diffContextBg":          { "dark": "blackhole_bg_soft", "light": "supernova_bg_soft" },
    "diffLineNumber":         { "dark": "blackhole_fg_muted", "light": "supernova_fg_muted" },
    "diffAddedLineNumberBg":  { "dark": "diff_add_bg_dark", "light": "diff_add_bg_light" },
    "diffRemovedLineNumberBg":{ "dark": "diff_rem_bg_dark", "light": "diff_rem_bg_light" },

    "markdownText":           { "dark": "blackhole_fg",      "light": "supernova_fg" },
    "markdownHeading":        { "dark": "blackhole_yellow",  "light": "supernova_yellow" },
    "markdownLink":           { "dark": "blackhole_blue",    "light": "supernova_blue" },
    "markdownLinkText":       { "dark": "blackhole_teal",    "light": "supernova_teal" },
    "markdownCode":           { "dark": "blackhole_green",   "light": "supernova_green" },
    "markdownBlockQuote":     { "dark": "blackhole_fg_muted","light": "supernova_fg_muted" },
    "markdownEmph":           { "dark": "blackhole_orange",  "light": "supernova_orange" },
    "markdownStrong":         { "dark": "blackhole_violet",  "light": "supernova_violet" },
    "markdownHorizontalRule": { "dark": "blackhole_border",  "light": "supernova_border" },
    "markdownListItem":       { "dark": "blackhole_yellow",  "light": "supernova_yellow" },
    "markdownListEnumeration":{ "dark": "blackhole_teal",    "light": "supernova_teal" },
    "markdownImage":          { "dark": "blackhole_blue",    "light": "supernova_blue" },
    "markdownImageText":      { "dark": "blackhole_teal",    "light": "supernova_teal" },
    "markdownCodeBlock":      { "dark": "blackhole_fg",      "light": "supernova_fg" },

    "syntaxComment":     { "dark": "blackhole_fg_muted","light": "supernova_fg_muted" },
    "syntaxKeyword":     { "dark": "blackhole_red",     "light": "supernova_red" },
    "syntaxFunction":    { "dark": "blackhole_blue",    "light": "supernova_blue" },
    "syntaxVariable":    { "dark": "blackhole_fg",      "light": "supernova_fg" },
    "syntaxString":      { "dark": "blackhole_green",   "light": "supernova_green" },
    "syntaxNumber":      { "dark": "blackhole_teal",    "light": "supernova_teal" },
    "syntaxType":        { "dark": "blackhole_violet",  "light": "supernova_violet" },
    "syntaxOperator":    { "dark": "blackhole_fg",      "light": "supernova_fg" },
    "syntaxPunctuation": { "dark": "blackhole_fg",      "light": "supernova_fg" }
  }
}
