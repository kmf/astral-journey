  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#99ccff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment Doc",
      "scope": [
        "comment.block.documentation",
        "string.quoted.docstring"
      ],
      "settings": {
        "foreground": "#8b90bd",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff6e6e",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword Operator",
      "scope": [
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.ternary",
        "keyword.operator.assignment"
      ],
      "settings": {
        "foreground": "#ff6e6e"
      }
    },
    {
      "name": "Storage Type",
      "scope": [
        "storage.type"
      ],
      "settings": {
        "foreground": "#b78ae0"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#7ed4a3"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#99ccff"
      }
    },
    {
      "name": "Number, Boolean, Null",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#ffcc99"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "variable.other.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#ffcc66"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#fdfbe4"
